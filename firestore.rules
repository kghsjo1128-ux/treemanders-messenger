rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function adminEmails() {
      return [
        'trmendous@treemanders.internal'
      ];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email in adminEmails();
    }

    function isOwnerEmail(email) {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email == email;
    }

    match /leaveRequests/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userEmail is string
        && isOwnerEmail(request.resource.data.userEmail);
      allow update: if isAdmin()
        || (resource.data.userEmail is string
            && isOwnerEmail(resource.data.userEmail)
            && request.resource.data.userEmail == resource.data.userEmail);
      allow delete: if isAdmin()
        || (resource.data.userEmail is string
            && isOwnerEmail(resource.data.userEmail));
    }

    match /employeeFixedOff/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /employeeApprovals/{uid} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == uid
            && request.resource.data.keys().hasAll(['uid', 'email'])
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.email == request.auth.token.email);
      allow update, delete: if isAdmin();
    }

    match /userPasswordMeta/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    /** 1:1 채팅: threadId = participants[0] + '__TM__' + participants[1] (이메일 소문자, 사전순 p0 < p1) */
    match /directDm/{threadId} {
      function dmEmailLower() {
        return request.auth.token.email == null
          ? ''
          : request.auth.token.email.lower();
      }

      function validDmThreadCreate() {
        let p = request.resource.data.participants;
        return p is list && p.size() == 2
          && p[0] is string && p[1] is string
          && p[0] == p[0].lower() && p[1] == p[1].lower()
          && p[0] < p[1]
          && threadId == p[0] + '__TM__' + p[1]
          && dmEmailLower() in p;
      }

      allow read: if isSignedIn()
        && resource.exists
        && request.auth.token.email != null
        && dmEmailLower() in resource.data.participants;
      allow create: if isSignedIn() && validDmThreadCreate();
      allow update: if isSignedIn()
        && resource.exists
        && request.auth.token.email != null
        && dmEmailLower() in resource.data.participants
        && request.resource.data.participants == resource.data.participants;
      allow delete: if false;
    }

    match /directDm/{threadId}/messages/{msgId} {
      function dmThreadDoc() {
        return get(/databases/$(database)/documents/directDm/$(threadId));
      }

      function dmMsgParticipant() {
        return isSignedIn()
          && request.auth.token.email != null
          && dmThreadDoc().exists
          && request.auth.token.email.lower() in dmThreadDoc().data.participants;
      }

      allow read: if dmMsgParticipant();
      allow create: if dmMsgParticipant()
        && request.resource.data.senderEmail == request.auth.token.email.lower()
        && request.resource.data.senderName is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 8000;
      allow delete: if dmMsgParticipant();
      allow update: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
